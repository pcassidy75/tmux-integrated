                <mxCell id="client_commands" value="&lt;b&gt;Command API&lt;/b&gt;&lt;hr size=&quot;1&quot;/&gt;• sendCommand(cmd) → Promise&amp;lt;string[]&amp;gt;&lt;br/&gt;• newWindow(opts) → {windowId, paneId}&lt;br/&gt;• killWindow(windowId)&lt;br/&gt;• listWindows() → TmuxWindow[]&lt;br/&gt;• resizePane() / resizeWindowForClient()&lt;br/&gt;• capturePane() → screen snapshot&lt;br/&gt;• getPaneCursor() → {x, y}&lt;br/&gt;• getPaneTty() → /dev/pts/N&lt;br/&gt;• respawnPane()&lt;br/&gt;• updateEnvironment(vars)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;verticalAlign=top;spacingTop=4;" parent="1" vertex="1">

{
  "name": "tmux-integrated",
  "displayName": "tmux-integrated",
  "description": "Seamless tmux integration for VS Code terminals — persistent sessions, code-command support, and Copilot compatibility",
  "version": "0.1.2",
  "publisher": "pcassidy75",
  "license": "GPL-3.0-only",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/pcassidy75/tmux-integrated"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "tmux",
    "terminal",
    "persistent",
    "session"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "terminal": {
      "profiles": [
        {
          "id": "tmux-integrated.terminal",
          "title": "tmux-integrated"
        }
      ]
    },
    "commands": [
      {
        "command": "tmux-integrated.newTerminal",
        "title": "New tmux Terminal",
        "category": "tmux"
      },
      {
        "command": "tmux-integrated.attachWindow",
        "title": "Attach to tmux Window",
        "category": "tmux"
      }
    ],
    "configuration": {
      "title": "tmux-integrated",
      "properties": {
        "tmux-integrated.sessionName": {
          "type": "string",
          "default": "",
          "description": "Override the tmux session name. Defaults to the workspace folder name."
        },
        "tmux-integrated.shell": {
          "type": "string",
          "default": "",
          "description": "Shell to use inside tmux panes. Defaults to $SHELL or /bin/bash."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "release": "npm version patch && git push --follow-tags"
  },
  "devDependencies": {
    "@types/node": "^18.x",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.1.0"
  }
}
